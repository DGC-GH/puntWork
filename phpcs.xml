<?xml version="1.0"?>
<ruleset name="PuntWork WordPress Plugin">
    <description>PuntWork WordPress Plugin Coding Standards - Optimized for Grok Code Fast 1 copilot agent</description>

    <!-- Use WordPress coding standards as the primary standard -->
    <rule ref="WordPress"/>
    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Extra"/>

    <!-- Set the minimum PHP version for this project -->
    <config name="testVersion" value="8.1-"/>

    <!-- Exclude directories that shouldn't be checked -->
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>feeds/*</exclude-pattern>
    <exclude-pattern>cache/*</exclude-pattern>
    <exclude-pattern>*.log</exclude-pattern>

    <!-- Line length limit appropriate for modern displays -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="120"/>
        </properties>
    </rule>

    <!-- Allow some WordPress-specific naming conventions -->
    <rule ref="WordPress.Files.FileName">
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    </rule>

    <!-- Allow long arrays for readability in WordPress contexts -->
    <rule ref="WordPress.Arrays.ArrayDeclarationSpacing"/>
</ruleset>