{
    "name": "dgc-gh/puntwork",
    "description": "WordPress plugin for importing jobs from XML feeds",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "open-telemetry/api": "^1.6",
        "open-telemetry/sdk": "^1.8",
        "open-telemetry/context": "^1.4",
        "guzzlehttp/promises": "^2.3",
        "php-http/httplug": "^2.4",
        "symfony/http-client": "^7.3",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Puntwork\\": "includes/"
        },
        "classmap": [
            "includes/utilities/ImportAnalytics.php",
            "includes/utilities/JobDeduplicator.php",
            "includes/utilities/FeedHealthMonitor.php",
            "includes/import/feed-processor.php",
            "includes/ai/job-categorizer.php",
            "includes/ai/duplicate-detector.php",
            "includes/ai/content-quality-scorer.php",
            "includes/crm/crm-integration.php",
            "includes/crm/crm-manager.php",
            "includes/crm/hubspot-integration.php",
            "includes/crm/salesforce-integration.php",
            "includes/crm/zoho-integration.php",
            "includes/crm/pipedrive-integration.php"
        ]
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    }
}
