{
    "name": "dgc-gh/puntwork",
    "description": "WordPress plugin for importing jobs from XML feeds",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "open-telemetry/opentelemetry": "^1.0",
        "guzzlehttp/promises": "^2.3",
        "php-http/httplug": "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "wp-cli/wp-cli": "^2.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "autoload": {
        "psr-4": {
            "Puntwork\\": "includes/"
        },
        "classmap": [
            "includes/utilities/import-analytics.php",
            "includes/utilities/advanced-deduplication.php",
            "includes/utilities/feed-health-monitor.php",
            "includes/import/feed-processor.php",
            "includes/ai/job-categorizer.php",
            "includes/ai/duplicate-detector.php",
            "includes/ai/content-quality-scorer.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    }
}
